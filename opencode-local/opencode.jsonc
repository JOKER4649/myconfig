{
  // 個人 overlay：僅互動式使用時透過 OPENCODE_CONFIG_DIR 疊加於共用 base 之上。
  // 這裡放與「個人 agent 陣容」耦合的設定；base（multica 共用）保持中性原生。
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "copilot",
  "agent": {
    "general": { "disable": true },
    "plan": { "disable": true },
    "build": { "disable": true }
  }
}
