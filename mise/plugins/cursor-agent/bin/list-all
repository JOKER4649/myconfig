#!/usr/bin/env bash
set -euo pipefail

# 從官方安裝腳本中解析最新版本
# 版本格式: YYYY.MM.DD-<hash> (例如 2026.05.27-fe9a6e2)
script=$(curl -fsS https://cursor.com/install 2>/dev/null) || {
  echo "cursor-agent: 無法獲取版本列表" >&2
  exit 1
}

version=$(echo "$script" | grep -oP 'DOWNLOAD_URL="[^"]*/lab/\K[^/"]+' | head -1)
if [ -z "$version" ]; then
  echo "cursor-agent: 無法從安裝腳本解析版本" >&2
  exit 1
fi
echo "$version"
