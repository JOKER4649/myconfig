#!/usr/bin/env bash
set -euo pipefail

version="${ASDF_INSTALL_VERSION:?}"
install_path="${ASDF_INSTALL_PATH:?}"

os=$(uname -s | tr '[:upper:]' '[:lower:]')
arch=$(uname -m)
case "$arch" in
  x86_64|amd64) arch="x64" ;;
  arm64|aarch64) arch="arm64" ;;
  *)
    echo "cursor-agent: unsupported architecture: $arch" >&2
    exit 1
    ;;
esac

download_url="https://downloads.cursor.com/lab/${version}/${os}/${arch}/agent-cli-package.tar.gz"

echo "cursor-agent: downloading $download_url ..."
mkdir -p "$install_path/bin"

if curl -fSL "$download_url" | tar --strip-components=1 -xzf - -C "$install_path/bin"; then
  chmod +x "$install_path/bin/cursor-agent" 2>/dev/null || true
  ln -sf cursor-agent "$install_path/bin/agent" 2>/dev/null || true
  echo "cursor-agent $version installed"
else
  echo "cursor-agent: download failed" >&2
  exit 1
fi
