# Oh My Pi 執行期資料（不追蹤）
# 只追蹤 agent/config.yml

# 上次讀過的 changelog 版本（每台機器各自維護，跨機器無意義）
agent/last-changelog-version

# 硬體/系統快取
gpu_cache.json

# SQLite 資料庫與 WAL
*.db
*.db-shm
*.db-wal

# Session 紀錄
agent/sessions/
agent/terminal-sessions/

# 執行日誌
logs/

# 安裝識別（每次安裝都不同）
install-id

# 下載的原生 binary（omp 安裝時自動抓）
natives/

# Plugin manager 自動產生（omp-plugins.lock.json 例外保留）
plugins/bun.lock
plugins/node_modules/
plugins/package.json
!plugins/omp-plugins.lock.json

# Puppeteer shim（runner 自動建立空 package.json）
puppeteer/package.json

# Broker runtime state（pid / token / socket）
run/
