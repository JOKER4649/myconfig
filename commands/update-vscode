#!/usr/bin/env -S uv run --script
# /// script
# dependencies = ["typer", "httpx"]
# ///
"""VS Code 一鍵更新工具（Ubuntu/Debian deb 安裝方式）"""

import subprocess
import sys
import tempfile
from pathlib import Path

import httpx
import typer

DOWNLOAD_URL = "https://update.code.visualstudio.com/latest/linux-deb-x64/stable"

app = typer.Typer(help="VS Code 一鍵更新工具")


def run(cmd: list[str], *, check: bool = True, capture: bool = False) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, check=check, capture_output=capture, text=True)


def get_current_version() -> str | None:
    """取得目前已安裝的 VS Code 版本"""
    try:
        result = run(["code", "--version"], capture=True)
        return result.stdout.strip().splitlines()[0]
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None


def get_latest_version() -> tuple[str, str]:
    """透過 redirect 取得最新版本號與下載 URL"""
    resp = httpx.head(DOWNLOAD_URL, follow_redirects=True)
    url = str(resp.url)
    # URL 格式: .../code_{version}-{build}_amd64.deb
    filename = url.rsplit("/", 1)[-1]
    version = filename.split("_")[1].split("-")[0]
    return version, url


@app.command()
def update(
    force: bool = typer.Option(False, "--force", "-f", help="強制重新安裝，即使版本相同"),
    check_only: bool = typer.Option(False, "--check", "-c", help="僅檢查是否有新版本，不安裝"),
):
    """下載並安裝最新版 VS Code"""
    current = get_current_version()
    print(f"目前版本: {current or '未安裝'}")

    print("檢查最新版本中...")
    latest, url = get_latest_version()
    print(f"最新版本: {latest}")

    if current == latest and not force:
        print("\n✓ 已經是最新版本")
        raise typer.Exit()

    if check_only:
        if current != latest:
            print(f"\n有新版本可用: {current} → {latest}")
        raise typer.Exit()

    print(f"\n下載中: {current or '無'} → {latest}")

    with tempfile.TemporaryDirectory() as tmpdir:
        deb_path = Path(tmpdir) / "code_latest.deb"

        # 下載 .deb
        with httpx.stream("GET", url, follow_redirects=True) as resp:
            resp.raise_for_status()
            total = int(resp.headers.get("content-length", 0))
            downloaded = 0
            with open(deb_path, "wb") as f:
                for chunk in resp.iter_bytes(chunk_size=8192):
                    f.write(chunk)
                    downloaded += len(chunk)
                    if total:
                        pct = downloaded * 100 // total
                        print(f"\r  下載進度: {pct}% ({downloaded // 1024 // 1024}MB/{total // 1024 // 1024}MB)", end="", flush=True)
            print()

        # 安裝
        print("安裝中（需要 sudo 權限）...")
        run(["sudo", "dpkg", "-i", str(deb_path)])

    # 驗證
    new_version = get_current_version()
    print(f"\n✓ VS Code 已更新至 {new_version}")


if __name__ == "__main__":
    try:
        app()
    except subprocess.CalledProcessError as e:
        sys.exit(e.returncode)
