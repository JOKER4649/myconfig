#!/usr/bin/env bash
# oc-update-plugins — 更新 OpenCode plugin 快取，強制重新取得 @latest 版本
#
# OpenCode 的 plugin 快取在 ~/.cache/opencode/packages/ 中，
# 即使設定了 @latest，bun.lock 鎖定版本後不會主動更新。
# 此指令會清除 @latest 快取並以 bun add 重新安裝每個 plugin。
#
# 用法:
#   oc-update-plugins             實際更新
#   oc-update-plugins -n          預覽模式
#   oc-update-plugins -c          連同舊版號目錄一起清除
#   oc-update-plugins -N          僅清除，不重新安裝
#   oc-update-plugins -h          顯示說明

set -euo pipefail

CACHE_DIR="$HOME/.cache/opencode"
PACKAGES_DIR="$CACHE_DIR/packages"
RED='\033[31m'
GREEN='\033[32m'
YELLOW='\033[33m'
DIM='\033[2m'
NC='\033[0m'

# ── 參數解析 ──
CLEAN_OLD=false
NO_INSTALL=false
DRY_RUN=false

usage() {
    cat <<EOF
oc-update-plugins — 更新 OpenCode plugin 快取

用法:
  oc-update-plugins [OPTIONS]

選項:
  -c, --clean-old   同時清除舊版號快取（如 oh-my-openagent@4.0.0）
  -N, --no-install  僅清除快取目錄，不重新安裝（下次啟動 opencode 時自動安裝）
  -n, --dry-run     預覽模式，只顯示將執行的操作，不實際修改
  -h, --help        顯示此說明

預設行為:
  1. 刪除 ~/.cache/opencode/packages/ 下所有 *@latest 目錄
  2. 刪除 ~/.cache/opencode/bun.lock（強制重新解析版本）
  3. 對每個 @latest plugin 執行 bun add 重新安裝
  4. 報告各 plugin 的當前版本
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -c|--clean-old) CLEAN_OLD=true; shift ;;
        -N|--no-install) NO_INSTALL=true; shift ;;
        -n|--dry-run) DRY_RUN=true; shift ;;
        -h|--help) usage ;;
        *) echo "未知選項: $1"; usage ;;
    esac
done

# ── 輔助函數 ──
is_version_dir() {
    local name="$1"
    [[ "$name" != @* ]] || return 1          # 跳過 @scoped packages
    [[ "$name" == *@* ]] || return 1         # 必須含 @
    local version="${name##*@}"
    [[ -n "$version" ]] || return 1
    # 版本號只含數字和 . - _ +
    [[ "$version" =~ ^[0-9][0-9._+\-]*$ ]] || return 1
    return 0
}

parse_version() {
    # 從 bun add 輸出中提取 "installed <name>@<version>" 的版本號
    local output="$1"
    local pkg="$2"
    echo "$output" | grep -oP "installed \Q$pkg\E@\K[0-9][0-9._+\-]*" | head -1
}

# ── 收集待清除的目錄 ──
TO_REMOVE=()
LATEST_NAMES=()

if [[ -d "$PACKAGES_DIR" ]]; then
    for entry in "$PACKAGES_DIR"/*; do
        [[ -d "$entry" ]] || continue
        name="$(basename "$entry")"

        # scoped package: @scope/ 底下可能有多個 plugin
        if [[ "$name" == @* ]]; then
            for sub in "$entry"/*; do
                [[ -d "$sub" ]] || continue
                subname="$(basename "$sub")"
                if [[ "$subname" == *@latest ]]; then
                    TO_REMOVE+=("$sub")
                    LATEST_NAMES+=("${name}/${subname%@latest}")
                elif $CLEAN_OLD && is_version_dir "$subname"; then
                    TO_REMOVE+=("$sub")
                fi
            done
            continue
        fi

        # 一般 (非 scoped) package
        if [[ "$name" == *@latest ]]; then
            TO_REMOVE+=("$entry")
            LATEST_NAMES+=("${name%@latest}")
        elif $CLEAN_OLD && is_version_dir "$name"; then
            TO_REMOVE+=("$entry")
        fi
    done
fi

LOCKFILE="$PACKAGES_DIR/bun.lock"
HAS_LOCKFILE=false
[[ -f "$LOCKFILE" ]] && HAS_LOCKFILE=true

# ── 無需處理 ──
if [[ ${#TO_REMOVE[@]} -eq 0 ]] && ! $HAS_LOCKFILE; then
    echo -e "${GREEN}✓ 無需更新，快取已經是乾淨的${NC}"
    exit 0
fi

# ── dry-run 摘要 ──
if $DRY_RUN; then
    echo -e "${YELLOW}=== 預覽模式（移除 -n 實際執行）===${NC}\n"
fi

if [[ ${#TO_REMOVE[@]} -gt 0 ]]; then
    echo "將清除 ${#TO_REMOVE[@]} 個快取目錄："
    for p in "${TO_REMOVE[@]}"; do
        echo "  $(basename "$p")"
    done
else
    echo "沒有需要清除的快取目錄"
fi

if $HAS_LOCKFILE; then
    echo ""
    echo "將刪除 lockfile: $LOCKFILE"
fi

if ! $NO_INSTALL && [[ ${#LATEST_NAMES[@]} -gt 0 ]]; then
    echo ""
    echo "將重新安裝 ${#LATEST_NAMES[@]} 個 plugin："
    for n in "${LATEST_NAMES[@]}"; do
        echo "  ${n}@latest"
    done
fi

$DRY_RUN && exit 0

# ── 清除 ──
for p in "${TO_REMOVE[@]}"; do
    echo "  移除 $(basename "$p") ..."
    rm -rf "$p"
done

if $HAS_LOCKFILE; then
    rm -f "$LOCKFILE"
    echo "  已刪除 bun.lock"
fi

# ── 重新安裝 ──
if $NO_INSTALL; then
    echo ""
    echo -e "${GREEN}✓ 快取已清除（略過安裝，下次啟動 opencode 時將自動安裝）${NC}"
    exit 0
fi

if [[ ${#LATEST_NAMES[@]} -eq 0 ]]; then
    echo ""
    echo -e "${GREEN}✓ 快取已清除（無需重新安裝的 plugin）${NC}"
    exit 0
fi

if ! command -v bun &>/dev/null; then
    echo -e "${RED}❌ 找不到 bun。快取已清除，但需要手動執行 bun install。${NC}"
    echo "   可使用 mise 安裝：mise install bun"
    exit 1
fi

echo ""
echo "重新安裝 ${#LATEST_NAMES[@]} 個 plugin ..."
echo ""

# 確保 workspace package.json 存在（bun add 需要它才能安裝到 workspace 共用 node_modules）
WORKSPACE_PKG="$PACKAGES_DIR/package.json"
if [[ ! -f "$WORKSPACE_PKG" ]]; then
    echo '{"dependencies": {}}' > "$WORKSPACE_PKG"
fi

declare -A RESULTS
FAILED=()

for pkg_name in "${LATEST_NAMES[@]}"; do
    pkg_dir="$PACKAGES_DIR/${pkg_name}@latest"
    mkdir -p "$pkg_dir"
    echo -n "  ${pkg_name}@latest ... "

    output=$(cd "$pkg_dir" && bun add "${pkg_name}@latest" 2>&1) || true

    version=$(parse_version "$output" "$pkg_name")
    if [[ -n "$version" ]]; then
        RESULTS["$pkg_name"]="$version"
        echo -e "${GREEN}✓ ${version}${NC}"

        # 建立 OpenCode 格式的 marker package.json（與 opencode plugin 指令一致）
        printf -v pkg_json '{\n  "dependencies": {\n    "%s": "%s"\n  }\n}' "$pkg_name" "$version"
        echo "$pkg_json" > "$pkg_dir/package.json"

        # 清除 bun add 在 plugin 目錄內產生的 node_modules 與 bun.lock
        # （實際程式碼在 workspace node_modules 中，plugin 目錄只需保留 marker）
        rm -rf "$pkg_dir/node_modules" "$pkg_dir/bun.lock" 2>/dev/null || true
    else
        FAILED+=("$pkg_name")
        echo -e "${RED}❌ 安裝失敗${NC}"
        echo "    $(echo "$output" | tail -3 | tr '\n' ' ')"
    fi
done
# ── 版本報告 ──
if [[ ${#RESULTS[@]} -gt 0 ]]; then
    echo ""
    printf "%-35s %s\n" "Plugin" "版本"
    printf "%-35s %s\n" "-----------------------------------" "------"
    for name in $(printf '%s\n' "${!RESULTS[@]}" | sort); do
        printf "%-35s %s\n" "$name" "${RESULTS[$name]}"
    done
fi

for name in "${FAILED[@]}"; do
    echo ""
    echo -e "  ${name}  ${RED}❌ 安裝失敗，請手動檢查${NC}"
done

if [[ ${#FAILED[@]} -eq 0 ]]; then
    echo ""
    echo -e "${GREEN}✓ OpenCode plugin 快取已更新${NC}"
else
    echo ""
    echo -e "${YELLOW}⚠ ${#FAILED[@]}/${#LATEST_NAMES[@]} plugin 更新失敗${NC}"
fi
