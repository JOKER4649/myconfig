# 解析與驗證
# ============================================================


def parse_size(size_str: str) -> int:
    """將 '32G' / '16GiB' 解析為 bytes。拒絕 SI 單位 (GB/MB) 以免歧義。"""
    m = re.fullmatch(
        r"(\d+(?:\.\d+)?)([KMGTPE](?:iB)?)", size_str.strip(), re.IGNORECASE
    )
    if not m:
        die(f"非法的 size: {size_str!r}（請用 IEC 單位，例如 '32G', '16G', '2T'）")
    num = float(m.group(1))
    unit = m.group(2).upper().replace("IB", "")
    multipliers = {
        "K": 1024, "M": 1024**2, "G": 1024**3,
        "T": 1024**4, "P": 1024**5, "E": 1024**6,
    }
    return int(num * multipliers[unit])


def parse_version(v: str) -> tuple[int, ...]:
    """'6.19.1' -> (6, 19, 1)。"""
    nums = re.findall(r"\d+", v)
    return tuple(int(x) for x in nums[:3])


def check_root() -> None:
    if os.geteuid() != 0:
        die("需要 root 權限（試試: sudo setup-zswap ...）")


# ============================================================
# 狀態查詢（所有查詢都是唯讀）
# ============================================================


def get_active_swap_names() -> list[str]:
    r = run(["swapon", "--show=NAME", "--noheadings"], check=False)
    if r.returncode != 0:
        return []
    return r.stdout.split()


def get_active_zram_devices() -> list[str]:
    return [x for x in get_active_swap_names() if x.startswith("/dev/zram")]


def get_kernel_args_state() -> tuple[dict[str, bool], bool]:
    """讀取 grubby 一次,回傳 (key -> 生效值是否等於預期值, grubby_readable)。

    重要:kernel 命令行同名參數有多個時,最後一個生效(last-wins)。
    例如 args="... zswap.compressor=lzo ... zswap.compressor=zstd ..." 時,
    生效的是 zstd。此函數比對最後一個值,不是機械地檢查 token 存在。

    grubby_readable=False 時代表無法讀 grubby(通常是 non-root)。
    檢查範圍:ALL kernel entries 的生效值都是預期值才算 True。
    """
    result = {key: False for key in ZSWAP_ARGS}
    r = run(["grubby", "--info=ALL"], check=False)
    # 非 root 時 grubby 通常 exit 0 但 stdout 為空(內部 grep 失敗到 stderr)
    if r.returncode != 0 or not r.stdout.strip():
        return result, False
    entries_args = re.findall(r'^args="([^"]*)"', r.stdout, flags=re.MULTILINE)
    if not entries_args:
        return result, False
    for key, expected in ZSWAP_ARGS.items():
        prefix = f"{key}="
        # ALL entries 都必須最後一個 key=... 等於 expected
        all_entries_correct = True
        for args_line in entries_args:
            matches = [t for t in args_line.split() if t.startswith(prefix)]
            if not matches:
                all_entries_correct = False
                break
            # last-wins: 取最後一個的值
            last_value = matches[-1].split("=", 1)[1]
            if last_value != expected:
                all_entries_correct = False
                break
        result[key] = all_entries_correct
    return result, True


def fstab_has_our_swapfile() -> bool:
    try:
        content = FSTAB.read_text()
    except OSError:
        return False
    for line in content.splitlines():
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        parts = stripped.split()
        # 格式: <file> <mount> <type> <opts> <dump> <pass>
        if len(parts) >= 3 and parts[0] == str(SWAP_FILE) and parts[2] == "swap":
            return True
    return False


def is_subvolume(path: Path) -> bool:
    """檢查 path 是否為 btrfs subvolume。

    使用 btrfs 文件系統特徵:subvolume 的根負載 inode 永遠 = 256。
    這個方法不需 root(stat 任何人都可以做),比 btrfs subvolume show 更通用。
    參考:https://btrfs.readthedocs.io/en/latest/Subvolumes.html
    """
    if not path.is_dir():
        return False
    try:
        return path.stat().st_ino == 256
    except OSError:
        return False


def is_swapfile_valid(path: Path, expected_size: int) -> bool:
    """檢查 path 是 swap file 格式且大小正確。

    非 root 時 swap file 是 0600 root:root,`file -b` 會因 permission 無法讀內容。
    此時倒回到檔名+大小判斷(dry-run 預覽時 acceptable,實際 run 會有 root)。
    """
    if not path.is_file():
        return False
    try:
        if path.stat().st_size != expected_size:
            return False
    except OSError:
        return False
    r = run(["file", "-b", str(path)], check=False)
    # `file` 在無讀權時會在 stdout 印"regular file, no read permission"(exit 0)
    # 或 stderr: "cannot open"
    out_lower = (r.stdout or "").lower()
    err_lower = (r.stderr or "").lower()
    if "no read permission" in out_lower or "cannot open" in err_lower:
        # 無法讀檔內容(非 root),大小已相符 → 信任為 swap file
        return True
    return "swap file" in out_lower


@dataclass
class State:
    zram_masked: bool
    zram_active_devices: list[str]
    subvol_exists: bool
    subvol_is_subvol: bool
    swapfile_exists: bool
    swapfile_valid: bool  # 格式 + 大小都對
    swapfile_active: bool
    fstab_ok: bool
    kernel_args_ok: dict[str, bool]  # key -> 是否已設為預期值
    kernel_args_readable: bool  # False 時 kernel_args_ok 不可靠(通常 non-root)
    zswap_runtime_enabled: bool | None  # None = 未知
    tune_applied: bool  # /etc/sysctl.d/99-zswap-tuning.conf 存在且有我們的 marker


def _is_tune_applied() -> bool:
    """檢查我們的 sysctl tuning 檔是否存在且有正確 marker。"""
    if not SYSCTL_CONF.is_file():
        return False
    try:
        return SYSCTL_MARKER in SYSCTL_CONF.read_text()
    except OSError:
        return False


def get_state(expected_swapfile_bytes: int) -> State:
    zram_masked = (
        ZRAM_CONF.is_symlink() and ZRAM_CONF.readlink() == Path("/dev/null")
    )
    active_swaps = get_active_swap_names()
    zram_devs = [x for x in active_swaps if x.startswith("/dev/zram")]

    subvol_exists = SWAP_SUBVOL.is_dir()
    subvol_is_subvol = is_subvolume(SWAP_SUBVOL) if subvol_exists else False

    swapfile_exists = SWAP_FILE.is_file()
    swapfile_valid = (
        is_swapfile_valid(SWAP_FILE, expected_swapfile_bytes)
        if swapfile_exists else False
    )
    swapfile_active = str(SWAP_FILE) in active_swaps

    # /sys/module/zswap runtime
    zswap_runtime_enabled: bool | None = None
    ze_path = Path("/sys/module/zswap/parameters/enabled")
    if ze_path.is_file():
        with contextlib.suppress(OSError):
            zswap_runtime_enabled = ze_path.read_text().strip().upper() == "Y"

    # grubby 需要 root 讀取 /boot/grub2/grubenv,非 root 時 kernel_args_readable=False
    kernel_args_ok, kernel_args_readable = get_kernel_args_state()

    return State(
        zram_masked=zram_masked,
        zram_active_devices=zram_devs,
        subvol_exists=subvol_exists,
        subvol_is_subvol=subvol_is_subvol,
        swapfile_exists=swapfile_exists,
        swapfile_valid=swapfile_valid,
        swapfile_active=swapfile_active,
        fstab_ok=fstab_has_our_swapfile(),
        kernel_args_ok=kernel_args_ok,
        kernel_args_readable=kernel_args_readable,
        zswap_runtime_enabled=zswap_runtime_enabled,
        tune_applied=_is_tune_applied(),
    )


# ============================================================
# Preflight
# ============================================================


def preflight(expected_swapfile_bytes: int) -> None:
    log("Preflight 檢查...")

    # 1. OS 類型（警告非 Fedora，但不 block）
    if Path("/etc/os-release").is_file():
        osr = Path("/etc/os-release").read_text()
        m = re.search(r"^ID=(.+)$", osr, re.MULTILINE)
        os_id = m.group(1).strip('"') if m else "unknown"
        if os_id != "fedora":
            warn(f"非 Fedora 系統（偵測到: {os_id}），未測試但嘗試繼續")

    # 2. 根檔案系統必須是 btrfs 且單設備
    r = run(["findmnt", "-n", "-o", "SOURCE,FSTYPE", "-T", "/"])
    parts = r.stdout.strip().split()
    if len(parts) < 2:
        die(f"findmnt 回傳異常: {r.stdout!r}")
    _, fstype = parts[0], parts[1]
    if fstype != "btrfs":
        die(f"根檔案系統不是 btrfs（是 {fstype}），本腳本不支援")

    # 使用 mount point 而非 device 路徑,避免 non-root 時 btrfs 無法存取區塊裝置
    # (btrfs fi show <mount> 用 mountinfo,不需 root;而 <device> 需能開裝置)
    r = run(["btrfs", "filesystem", "show", "/"], check=False)
    # 優先用 'Total devices N' 數字(比 devid 行數更可靠)
    m_total = re.search(r"Total devices\s+(\d+)", r.stdout)
    if m_total:
        device_count = int(m_total.group(1))
    else:
        # fallback 到數 devid 行
        device_count = len(re.findall(r"^\s*devid\s+", r.stdout, re.MULTILINE))
    if device_count == 0:
        warn("無法解析 btrfs 裝置數 (btrfs fi show 輸出異常),繼續但可能失敗")
    elif device_count > 1:
        die(f"偵測到多設備 btrfs ({device_count} devices),swapfile 不被支援")

    # 3. Kernel 版本
    kver = parse_version(os.uname().release)
    if kver < MIN_KERNEL:
        die(
            f"Kernel {os.uname().release} 過舊，"
            f"需要 >= {'.'.join(map(str, MIN_KERNEL))}"
        )
    if kver < (6, 8):
        warn(
            f"Kernel {os.uname().release} < 6.8: "
            "zswap.shrinker_enabled 無效果（仍會設定以備未來 kernel 升級）"
        )

    # 4. btrfs-progs 版本
    r = run(["btrfs", "--version"])
    bm = re.search(r"v(\d+\.\d+(?:\.\d+)?)", r.stdout)
    if not bm:
        die(f"無法解析 btrfs 版本: {r.stdout!r}")
    bver = parse_version(bm.group(1))
    if bver < MIN_BTRFS_PROGS:
        die(
            f"btrfs-progs {bm.group(1)} 過舊，"
            f"需要 >= {'.'.join(map(str, MIN_BTRFS_PROGS))}（需 mkswapfile 子命令）"
        )

    # 5. grubby 存在
    if not shutil.which("grubby"):
        die("grubby 不存在（非 Fedora/RHEL 系統？）")

    # 6. 磁碟空間（含 1GB buffer）
    r = run(["df", "--output=avail", "-B1", "/"])
    lines = r.stdout.strip().splitlines()
    if len(lines) < 2:
        die(f"df 輸出異常: {r.stdout!r}")
    avail_bytes = int(lines[-1])
    required = expected_swapfile_bytes + 1024**3
    if avail_bytes < required:
        die(
            f"磁碟空間不足：需要 {required / 1024**3:.1f} GB（含 1GB buffer），"
            f"僅有 {avail_bytes / 1024**3:.1f} GB"
        )

    # 7. 檢查 zram-generator 的 drop-in 目錄(我們只 mask 主 conf,不會處理 drop-ins)
    dropin_dir = Path("/etc/systemd/zram-generator.conf.d")
    if dropin_dir.is_dir():
        dropins = [p for p in dropin_dir.iterdir() if p.suffix == ".conf"]
        if dropins:
            warn(
                f"偵測到 {dropin_dir} 有 drop-in 設定: "
                f"{[p.name for p in dropins]}"
            )
            warn("此腳本只 mask 主 conf,drop-ins 仍可能使 zram-generator 產出設定。")
            warn("如確定要完全停 zram,請手動處理這些 drop-ins。")

    ok(
        f"Preflight 通過 "
        f"(kernel {'.'.join(map(str, kver))} / btrfs-progs {bm.group(1)})"
    )


# ============================================================
# 遷移步驟
# ============================================================


def step_disable_zram(dry_run: bool, state: State) -> None:
    log("步驟 1/3：停用 Fedora zram-generator")

    if state.zram_masked:
        ok(f"{ZRAM_CONF} 已 mask 為 /dev/null")
    else:
        # 判斷現有狀態:regular file / 錯誤 symlink / dead symlink / 不存在
        is_link = ZRAM_CONF.is_symlink()
        is_file = ZRAM_CONF.exists() and not is_link

        # (a) regular file 有內容 → 備份
        if is_file:
            ts = datetime.now().strftime("%Y%m%d-%H%M%S")
            bak = ZRAM_CONF.with_name(f"{ZRAM_CONF.name}.bak.{ts}")
            if dry_run:
                log(f"[dry-run] 備份: {ZRAM_CONF} -> {bak}")
            else:
                ZRAM_CONF.rename(bak)
                warn(f"已備份原設定: {bak}")
        # (b) 錯誤 symlink 或 dead symlink → 先 unlink
        elif is_link:
            if dry_run:
                log(f"[dry-run] unlink 既有 symlink {ZRAM_CONF} (指向非 /dev/null)")
            else:
                ZRAM_CONF.unlink()
                warn(f"已移除既有 symlink {ZRAM_CONF}")

        # 現在 ZRAM_CONF 確定不存在(或這是 dry-run)→建立 mask symlink
        if dry_run:
            log(f"[dry-run] ln -sf /dev/null {ZRAM_CONF}")
        else:
            ZRAM_CONF.symlink_to("/dev/null")
            ok(f"Masked {ZRAM_CONF} -> /dev/null")

    # 正確順序:daemon-reload(讓 systemd 忘記 zram-setup unit) → swapoff → zramctl --reset
    # 這避免 systemd 在 swapoff 之後再次試圖啟動 unit(因為 mask 了但 unit 可能仍在內存)
    if not dry_run:
        run(["systemctl", "daemon-reload"], check=False)

    # 停用執行中的 zram
    for dev in state.zram_active_devices:
        if dry_run:
            log(f"[dry-run] swapoff {dev} && zramctl --reset {dev}")
        else:
            r = run(["swapoff", dev], check=False)
            if r.returncode != 0:
                warn(f"swapoff {dev} 失敗: {r.stderr.strip()}")
            else:
                ok(f"Deactivated {dev}")
            # 釋放 zram block device 背後的 RAM (swapoff 只是停用但不釋 RAM)
            if shutil.which("zramctl"):
                r = run(["zramctl", "--reset", dev], check=False)
                if r.returncode == 0:
                    ok(f"Reset {dev} (釋放 RAM)")
    if not state.zram_active_devices:
        ok("無執行中的 zram swap")


def step_create_swapfile(
    dry_run: bool, state: State, size_str: str, size_bytes: int
) -> None:
    log(f"步驟 2/3：建立 btrfs swapfile ({size_str}) @ {SWAP_FILE}")

    # 1. Subvolume
    if state.subvol_exists and not state.subvol_is_subvol:
        die(f"{SWAP_SUBVOL} 已存在但不是 btrfs subvolume（拒絕繼續，請手動處理）")
    if not state.subvol_exists:
        if dry_run:
            log(f"[dry-run] btrfs subvolume create {SWAP_SUBVOL}")
        else:
            run(["btrfs", "subvolume", "create", str(SWAP_SUBVOL)], capture=False)
            ok(f"建立 subvolume {SWAP_SUBVOL}")
    else:
        ok(f"Subvolume {SWAP_SUBVOL} 已存在")

    # 2. Swapfile
    if state.swapfile_valid:
        ok(f"Swapfile {SWAP_FILE} 已存在且正確 ({size_str})")
    else:
        if state.swapfile_exists:
            warn("既有 swapfile 不符預期 (size/format 不對)，重建")
            if state.swapfile_active:
                if dry_run:
                    log(f"[dry-run] swapoff {SWAP_FILE}")
                else:
                    run(["swapoff", str(SWAP_FILE)])
            if dry_run:
                log(f"[dry-run] rm {SWAP_FILE}")
            else:
                SWAP_FILE.unlink()

        if dry_run:
            log(f"[dry-run] btrfs filesystem mkswapfile --size {size_str} {SWAP_FILE}")
        else:
            # mkswapfile 自動處理 NOCOW flag + mkswap,專為 btrfs 設計
            run(
                ["btrfs", "filesystem", "mkswapfile", "--size", size_str, str(SWAP_FILE)],
                capture=False,
            )
            # SELinux context:Fedora 預設 policy 沒有 /swap/swapfile 的 fcontext rule,
            # 所以 restorecon 會 assign default_t → boot 時 systemd swapon 會失敗
            # (SELinux enforcing)。用 chcon 明確指定 swapfile_t 是最安全的方法。
            if shutil.which("chcon"):
                r = run(["chcon", "-t", "swapfile_t", str(SWAP_FILE)], check=False)
                if r.returncode != 0:
                    warn(f"chcon 失敗(SELinux 可能未安裝): {r.stderr.strip()}")
            ok(f"Swapfile {SWAP_FILE} 已建立 ({size_str})")

    # 3. fstab
    if state.fstab_ok:
        ok("/etc/fstab 已包含 swapfile 項目")
    else:
        fstab_line = f"{SWAP_FILE} none swap defaults 0 0"
        if dry_run:
            log(f"[dry-run] 加入 /etc/fstab:\n    {FSTAB_COMMENT}\n    {fstab_line}")
        else:
            content = FSTAB.read_text()
            if not content.endswith("\n"):
                content += "\n"
            content += f"\n{FSTAB_COMMENT}\n{fstab_line}\n"
            _atomic_write(FSTAB, content)
            ok("已加入 /etc/fstab")

    # 4. 啟用(只在非 dry-run 時查現狀,dry-run 就依 state)
    already_active = (
        state.swapfile_active if dry_run
        else str(SWAP_FILE) in get_active_swap_names()
    )
    if already_active:
        ok("Swapfile 已啟用")
    elif dry_run:
        log(f"[dry-run] swapon {SWAP_FILE}")
    else:
        run(["swapon", str(SWAP_FILE)])
        ok("已啟用 swapfile")


def step_enable_zswap(dry_run: bool, state: State) -> bool:
    """回傳 needs_reboot。"""
    log("步驟 3/3:啟用 zswap kernel 參數")

    if not state.kernel_args_readable:
        # 無法讀 grubby(非 root 或其他問題),不敢斷定已有哪些參數
        # dry-run 時:預設所有參數都會被加(讓使用者看到完整命令)
        # 非 dry-run 時:應該已經有 root 了,這種狀況很異常
        if not dry_run:
            die("無法讀 grubby(exit 異常或輸出為空),無法安全修改 kernel 參數")
        warn("(dry-run) 無 root 權限無法讀 grubby,下列命令可能是多餘(值已設)")

    args_to_add: list[str] = []
    for key, val in ZSWAP_ARGS.items():
        full_arg = f"{key}={val}"
        if state.kernel_args_readable and state.kernel_args_ok[key]:
            ok(f"Kernel arg 已設: {full_arg}")
        else:
            args_to_add.append(full_arg)

    if not args_to_add:
        ok("所有 zswap kernel 參數皆已就定位")
        return False

    # 檢出要新增的 keys (可能原本已存在但值不對)
    keys_to_reset = [arg.split("=", 1)[0] for arg in args_to_add]
    keys_str = " ".join(keys_to_reset)
    args_str = " ".join(args_to_add)
    if dry_run:
        log(f'[dry-run] grubby --update-kernel=ALL --remove-args="{keys_str}"')
        log(f'[dry-run] grubby --update-kernel=ALL --args="{args_str}"')
    else:
        # 先移除舊值(避免若既有 key=舊值 會被 append 而重複或支離破碑)
        run(
            ["grubby", "--update-kernel=ALL", f"--remove-args={keys_str}"],
            check=False,
            capture=False,
        )
        # 再新增正確值
        run(
            ["grubby", "--update-kernel=ALL", f"--args={args_str}"],
            capture=False,
        )
        ok(f"已設定 kernel 參數: {args_str}")
    return True

def _build_sysctl_content(values: dict[str, str]) -> str:
    """產生 /etc/sysctl.d/99-zswap-tuning.conf 的內容 (含說明註解)。"""
    lines = [
        SYSCTL_MARKER,
        "# 不要手動編輯此檔 - 以 setup-zswap --tune / --rollback 管理",
        "# 參考:https://www.kernel.org/doc/html/latest/admin-guide/sysctl/vm.html",
        "",
    ]
    for key, default_val, comment in TUNE_DEFAULTS:
        val = values.get(key, default_val)
        lines.append(f"# {comment}")
        lines.append(f"{key} = {val}")
        lines.append("")
    return "\n".join(lines)


def _apply_sysctl_runtime(values: dict[str, str]) -> None:
    """即時套用 sysctl 值到 runtime (即使檔案已寫)。"""
    for key, val in values.items():
        r = run(["sysctl", "-w", f"{key}={val}"], check=False)
        if r.returncode != 0:
            warn(f"sysctl -w {key}={val} 失敗: {r.stderr.strip()}")


def step_tune(dry_run: bool, state: State, swappiness: int | None) -> None:
    log("額外步驟:套用 zswap 相關 sysctl tuning")

    # 組變最終 values (支援 --swappiness 覆寫)
    values = {k: v for k, v, _ in TUNE_DEFAULTS}
    if swappiness is not None:
        values["vm.swappiness"] = str(swappiness)
    content = _build_sysctl_content(values)

    # 冪等檢查:若既有內容完全相同 → 只驗證 runtime 值
    need_write = True
    if SYSCTL_CONF.is_file():
        try:
            if SYSCTL_CONF.read_text() == content:
                ok(f"{SYSCTL_CONF} 已是最新 (相同內容)")
                need_write = False
        except OSError:
            pass

    if need_write:
        if dry_run:
            log(f"[dry-run] 寫入 {SYSCTL_CONF}:")
            for line in content.splitlines():
                log(f"    {line}")
        else:
            _atomic_write(SYSCTL_CONF, content)
            ok(f"已寫入 {SYSCTL_CONF}")

    # 即時套用 runtime 值 (sysctl --system 不會自動覆寫running值,所以手動 sysctl -w)
    if dry_run:
        for key, val in values.items():
            log(f"[dry-run] sysctl -w {key}={val}")
    else:
        _apply_sysctl_runtime(values)
        ok("sysctl 值已即時套用")

# ============================================================
# 驗證
# ============================================================


def verify(expected_swapfile_bytes: int) -> bool:
    log("驗證結果...")
    state = get_state(expected_swapfile_bytes)
    all_ok = True

    if state.swapfile_active:
        ok(f"Swapfile 已啟用: {SWAP_FILE}")
    else:
        err("Swapfile 未啟用")
        all_ok = False

    if state.zram_active_devices:
        warn(f"zram 仍活躍: {state.zram_active_devices}（重開機後消失）")
    else:
        ok("無 zram swap 活躍")

    if state.kernel_args_readable:
        for key, val in ZSWAP_ARGS.items():
            if state.kernel_args_ok[key]:
                ok(f"Kernel arg 就緒: {key}={val}")
            else:
                err(f"Kernel arg 缺失: {key}={val}")
                all_ok = False
    else:
        warn("無法讀 grubby 驗證 kernel 參數,請手動確認: sudo grubby --info=DEFAULT")
        all_ok = False

    if state.zswap_runtime_enabled:
        ok("zswap 目前已活躍（來自之前的 boot）")
    elif state.zswap_runtime_enabled is False:
        log("zswap 尚未活躍（重開機後會啟用）")

    return all_ok


# ============================================================
# Status（可不需要 root 執行）
