#!/usr/bin/env python3

"""setup-zswap — 將 Fedora 預設的 zram 切換為 zswap + btrfs swapfile。

設計目標：
- 冪等 (idempotent)：重跑安全，已完成步驟自動跳過
- 可攜：preflight 檢查 OS / 檔案系統 / kernel / 工具版本
- 可還原：--rollback 完整還原到 Fedora 預設 zram

用法（預設為預覽模式，--apply 才實際執行）：
    setup-zswap                            # 預覽遷移動作（不需 sudo）
    sudo setup-zswap --apply               # 實際執行遷移
    sudo setup-zswap --tune --apply        # 遷移 + 套用 sysctl tuning
    sudo setup-zswap --size 16G --apply    # 自訂大小
    setup-zswap --status                   # 顯示目前 swap 設定 (唯讀)
    sudo setup-zswap --rollback --apply    # 還原到 Fedora 預設

前置需求：
- Fedora（或相容：btrfs root + grubby 可用）
- 單設備 btrfs root filesystem
- Kernel >= 6.1（btrfs filesystem mkswapfile 子命令）
- btrfs-progs >= 6.1

重開機後生效：zswap kernel 參數只能透過 bootloader 傳入，migrate 之後需重開機。
"""

from __future__ import annotations

import argparse
import os
import re
import shutil
import subprocess
import sys
import contextlib
from dataclasses import dataclass
from datetime import datetime
from pathlib import Path
from typing import NoReturn

# ============================================================
# 組態
# ============================================================

SIZE_DEFAULT = "32G"
SWAP_SUBVOL = Path("/swap")
SWAP_FILE = SWAP_SUBVOL / "swapfile"
ZRAM_CONF = Path("/etc/systemd/zram-generator.conf")
FSTAB = Path("/etc/fstab")
FSTAB_COMMENT = "# setup-zswap: btrfs swapfile"

# zswap kernel 參數（kernel 6.x 最佳組合）
# 用 dict 維持插入順序並方便 lookup
ZSWAP_ARGS: dict[str, str] = {
    "zswap.enabled": "1",
    "zswap.compressor": "zstd",
    "zswap.zpool": "zsmalloc",
    "zswap.max_pool_percent": "20",
    "zswap.shrinker_enabled": "1",  # kernel 6.8+；舊 kernel 會忽略
}

MIN_KERNEL = (6, 1)
MIN_BTRFS_PROGS = (6, 1)

# ---- sysctl tuning (--tune) ----
SYSCTL_CONF = Path("/etc/sysctl.d/99-zswap-tuning.conf")
SYSCTL_MARKER = "# Generated by setup-zswap --tune"

# (key, default 值, 中文說明) - 順序 = sysctl 檔案寫入順序
TUNE_DEFAULTS: list[tuple[str, str, str]] = [
    (
        "vm.swappiness",
        "200",
        "積極使用 zswap (不玩遊戲的工作機: 寧可壓縮也不要 OOM; 0-200)",
    ),
    (
        "vm.page-cluster",
        "0",
        "壓縮 swap 不需預讀, 只解壓所需頁 (節省不必要的 CPU; 0-6, 2^N 頁)",
    ),
    (
        "vm.watermark_scale_factor",
        "100",
        "kswapd 較早啟動 reclaim (0.1% → 1% buffer; 默認 10, 建議 100-200)",
    ),
]

# ============================================================
# 彩色輸出
# ============================================================

_USE_COLOR = sys.stdout.isatty()


def _c(code: str, s: str) -> str:
    return f"\033[{code}m{s}\033[0m" if _USE_COLOR else s


def log(msg: str) -> None:
    print(f"{_c('1;34', '[*]')} {msg}")


def ok(msg: str) -> None:
    print(f"{_c('1;32', '[✓]')} {msg}")


def warn(msg: str) -> None:
    print(f"{_c('1;33', '[!]')} {msg}")


def err(msg: str) -> None:
    print(f"{_c('1;31', '[✗]')} {msg}", file=sys.stderr)


def die(msg: str, code: int = 1) -> NoReturn:
    err(msg)
    sys.exit(code)


# ============================================================
# subprocess helper
# ============================================================


def run(
    cmd: list[str],
    *,
    check: bool = True,
    capture: bool = True,
) -> subprocess.CompletedProcess[str]:
    """執行命令。預設捕獲輸出；互動式命令請傳 capture=False。"""
    return subprocess.run(cmd, check=check, capture_output=capture, text=True)

def _atomic_write(path: Path, content: str) -> None:
    """原子寫入:寫 tmp 檔 → fsync → rename → fsync(dir)。

    對 /etc/fstab 等關鍵系統檔案特別重要。
    步驟:
    1. 寫 tmp 檔案 + fsync(fd) → data 落盤
    2. rename(tmp → path) → atomic (同 filesystem)
    3. fsync(parent dir fd) → rename 本身落盤(避免斷電後重轉看到舊檔)
    """
    tmp = path.with_name(f".{path.name}.tmp.setup-zswap")
    fd = os.open(str(tmp), os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o644)
    try:
        os.write(fd, content.encode())
        os.fsync(fd)
    finally:
        os.close(fd)
    tmp.replace(path)  # atomic rename
    # fsync 父目錄 → 確保 rename 也落盤 (POSIX 推薦)
    dir_fd = os.open(str(path.parent), os.O_RDONLY)
    try:
        os.fsync(dir_fd)
    finally:
        os.close(dir_fd)

