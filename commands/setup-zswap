def show_status(size_bytes: int) -> None:
    print()
    log("=== swapon --show ===")
    r = run(["swapon", "--show"], check=False)
    print(r.stdout.rstrip() if r.stdout.strip() else "  (無 swap)")

    print()
    log("=== zram-generator 狀態 ===")
    if ZRAM_CONF.is_symlink() and os.readlink(ZRAM_CONF) == "/dev/null":
        ok(f"{ZRAM_CONF}: 已 mask")
    elif ZRAM_CONF.exists():
        warn(f"{ZRAM_CONF}: 有自訂設定（非 mask）")
    else:
        log(f"{ZRAM_CONF}: 不存在（Fedora 預設行為）")

    print()
    log("=== zswap 模組 (/sys/module/zswap/parameters) ===")
    zp = Path("/sys/module/zswap/parameters")
    if zp.is_dir():
        for p in sorted(zp.iterdir()):
            try:
                print(f"  {p.name:<24s} {p.read_text().strip()}")
            except OSError:
                pass
    else:
        print("  (zswap 模組未載入)")

    print()
    log("=== Kernel cmdline args (下次開機) ===")
    r = run(["grubby", "--info=DEFAULT"], check=False)
    if r.returncode == 0 and r.stdout.strip():
        m = re.search(r'^args="([^"]*)"', r.stdout, re.MULTILINE)
        if m:
            args = m.group(1).split()
            relevant = [a for a in args if a.startswith(("zswap.", "zram"))]
            if relevant:
                for a in relevant:
                    print(f"  {a}")
            else:
                print("  (無 zswap/zram 相關參數)")
        else:
            print("  (無法解析 grubby 輸出)")
    else:
        if os.geteuid() != 0:
            warn("grubby 讀取失敗,需要 root 才能讀 /boot/grub2/grubenv")
            log("請試: sudo setup-zswap --status")
        else:
            print("  (grubby 命令失敗)")

    print()
    log("=== sysctl tuning (setup-zswap --tune) ===")
    if _is_tune_applied():
        ok(f"{SYSCTL_CONF} 已套用")
        # 顯示我們關心的 key 的 runtime 值與檔案值
        for key, default_val, _ in TUNE_DEFAULTS:
            r = run(["sysctl", "-n", key], check=False)
            runtime_val = r.stdout.strip() if r.returncode == 0 else "?"
            print(f"  {key:<32} runtime={runtime_val}")
    else:
        print("  (未套用 --tune，目前走 kernel / 其他 config 的預設)")
        # 即使未套用，也顯示我們會調的 key 目前值，方便比較
        for key, default_val, _ in TUNE_DEFAULTS:
            r = run(["sysctl", "-n", key], check=False)
            runtime_val = r.stdout.strip() if r.returncode == 0 else "?"
            print(f"  {key:<32} runtime={runtime_val} (tune 會設 {default_val})")


# ============================================================
# Rollback
# ============================================================


def rollback(dry_run: bool, size_bytes: int) -> None:
    log("Rollback：還原到 Fedora 預設 zram")
    state = get_state(size_bytes)

    # 1. 移除 kernel args(用 bare key 清除,不管 value 是什麼都會被移除)
    keys = " ".join(ZSWAP_ARGS.keys())
    if dry_run:
        log(f'[dry-run] grubby --update-kernel=ALL --remove-args="{keys}"')
    else:
        run(
            ["grubby", "--update-kernel=ALL", f"--remove-args={keys}"],
            check=False,
            capture=False,
        )
        ok(f"已移除 kernel 參數: {keys}")

    # 2. swapoff
    if state.swapfile_active:
        if dry_run:
            log(f"[dry-run] swapoff {SWAP_FILE}")
        else:
            r = run(["swapoff", str(SWAP_FILE)], check=False)
            if r.returncode != 0:
                warn(f"swapoff 失敗: {r.stderr.strip()}")
            else:
                ok(f"已停用 {SWAP_FILE}")

    # 3. 清 fstab
    try:
        fstab_content_for_check = FSTAB.read_text(errors="ignore")
    except OSError:
        fstab_content_for_check = ""
    if state.fstab_ok or FSTAB_COMMENT in fstab_content_for_check:
        if dry_run:
            log("[dry-run] 從 /etc/fstab 移除 swapfile 項目與 comment")
        else:
            _cleanup_fstab()
            ok("已從 /etc/fstab 移除 swapfile")

    # 4. 刪 swapfile
    if state.swapfile_exists:
        if dry_run:
            log(f"[dry-run] rm {SWAP_FILE}")
        else:
            SWAP_FILE.unlink()
            ok(f"已刪除 {SWAP_FILE}")

    # 5. 刪 subvolume（僅當是我們建立的）
    if state.subvol_is_subvol:
        if dry_run:
            log(f"[dry-run] btrfs subvolume delete {SWAP_SUBVOL}")
        else:
            r = run(
                ["btrfs", "subvolume", "delete", str(SWAP_SUBVOL)], check=False
            )
            if r.returncode != 0:
                warn(f"subvolume delete 失敗: {r.stderr.strip()}")
            else:
                ok(f"已刪除 subvolume {SWAP_SUBVOL}")

    # 6. Unmask zram config(對称操作:unlink mask)
    if state.zram_masked:
        if dry_run:
            log(f"[dry-run] rm {ZRAM_CONF} (unmask)")
        else:
            ZRAM_CONF.unlink()
            ok(f"已 unmask {ZRAM_CONF}")

        # 6b. 恢復最近的 .bak 檔(如果有)→ 還原使用者自訂 zram 設定
        bak_pattern = f"{ZRAM_CONF.name}.bak.*"
        baks = sorted(ZRAM_CONF.parent.glob(bak_pattern))
        if baks:
            latest = baks[-1]  # 最新的(timestamp 排序)
            if dry_run:
                log(f"[dry-run] mv {latest} {ZRAM_CONF}(恢復原設定)")
            else:
                latest.rename(ZRAM_CONF)
                ok(f"已恢復原設定: {latest.name} → {ZRAM_CONF}")

    # 7. 移除 sysctl tuning (如果曾用過 --tune)
    if state.tune_applied:
        if dry_run:
            log(f"[dry-run] rm {SYSCTL_CONF}")
            log("[dry-run] sysctl --system  # 重讀所有 sysctl configs")
        else:
            SYSCTL_CONF.unlink()
            ok(f"已刪除 {SYSCTL_CONF}")
            # 重讀 sysctl configs (可能有其他 .conf 覆寫running值)
            run(["sysctl", "--system"], check=False, capture=False)
            warn("Runtime sysctl 值可能仍保留新值 (除非其他 config 有覆寫)")
            warn("若需完全還原 kernel 預設值，請重開機。")

    if not dry_run:
        run(["systemctl", "daemon-reload"], check=False)

    warn("Rollback 完成。請重開機以停用 zswap 並讓 Fedora 的 zram 重新生成。")


def _cleanup_fstab() -> None:
    """從 /etc/fstab 移除我們的 comment 與 swapfile entry。"""
    lines = FSTAB.read_text().splitlines()
    new_lines: list[str] = []
    i = 0
    while i < len(lines):
        line = lines[i]
        stripped = line.strip()

        # 我們的 comment：跳過 comment 本身，並跳過緊接其後的 swapfile entry
        if stripped == FSTAB_COMMENT:
            if i + 1 < len(lines):
                nxt = lines[i + 1].split()
                if len(nxt) >= 3 and nxt[0] == str(SWAP_FILE) and nxt[2] == "swap":
                    i += 2
                    continue
            i += 1
            continue

        # 任何直接匹配我們的 swapfile 路徑 + type=swap（獨立一行的 fallback）
        parts = stripped.split()
        if (
            not stripped.startswith("#")
            and len(parts) >= 3
            and parts[0] == str(SWAP_FILE)
            and parts[2] == "swap"
        ):
            i += 1
            continue

        new_lines.append(line)
        i += 1

    # 清理尾端多餘空行
    while new_lines and not new_lines[-1].strip():
        new_lines.pop()
    _atomic_write(FSTAB, "\n".join(new_lines) + "\n")


# ============================================================
# CLI
# ============================================================


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="setup-zswap",
        description="將 Fedora 預設的 zram 切換為 zswap + btrfs swapfile",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "範例（預設為預覽模式，--apply 才實際執行）：\n"
            "  setup-zswap                            # 預覽遷移動作\n"
            "  sudo setup-zswap --apply               # 實際執行遷移\n"
            "  sudo setup-zswap --tune --apply        # 遷移 + 套用 sysctl tuning\n"
            "  sudo setup-zswap --size 16G --apply    # 自訂大小\n"
            "  sudo setup-zswap --swappiness 180 --apply  # 覆寫 swappiness\n"
            "  setup-zswap --status                   # 檢查目前狀態 (唯讀)\n"
            "  sudo setup-zswap --rollback --apply    # 還原 (連 tune 一起)"
        ),
    )
    parser.add_argument(
        "--size",
        default=SIZE_DEFAULT,
        help=f"Swapfile 大小 (預設: {SIZE_DEFAULT}，請用 IEC 單位如 32G)",
    )
    parser.add_argument(
        "--apply",
        action="store_true",
        help="實際執行變更（預設為預覽模式，和 link.py 慈例一致）",
    )
    parser.add_argument(
        "--tune",
        action="store_true",
        help="一併套用 zswap 的 sysctl tuning (swappiness=200, page-cluster=0 等)",
    )
    parser.add_argument(
        "--swappiness",
        type=int,
        metavar="N",
        help="覆寫 vm.swappiness (0-200，預設 200；暗含 --tune)",
    )
    mode = parser.add_mutually_exclusive_group()
    mode.add_argument(
        "--status", action="store_true", help="顯示目前 swap 設定後離開"
    )
    mode.add_argument(
        "--rollback", action="store_true", help="還原到 Fedora 預設 zram"
    )
    args = parser.parse_args()

    # --swappiness 暗含 --tune (使用者設了 swappiness 就是想 tune)
    if args.swappiness is not None:
        args.tune = True
        if not 0 <= args.swappiness <= 200:
            die(f"--swappiness 範圍 0-200，收到: {args.swappiness}")

    # 預設為預覽模式，--apply 才實際執行
    dry_run = not args.apply

    size_bytes = parse_size(args.size)

    # --status 不需要 root
    if args.status:
        show_status(size_bytes)
        return 0

    if dry_run:
        warn("預覽模式：僅顯示將執行的動作，不會實際變更（加 --apply 實際執行）")
    else:
        check_root()

    if args.rollback:
        rollback(dry_run, size_bytes)
        return 0

    # 正常遷移流程
    preflight(size_bytes)
    print()

    state = get_state(size_bytes)
    step_disable_zram(dry_run, state)
    print()

    # 第 1 步改動後重新讀 state，讓 2/3 步做正確的 idempotent 判斷
    state = get_state(size_bytes)
    step_create_swapfile(dry_run, state, args.size, size_bytes)
    print()

    state = get_state(size_bytes)
    needs_reboot = step_enable_zswap(dry_run, state)
    print()

    # 可選的 tuning 步驟
    if args.tune:
        state = get_state(size_bytes)
        step_tune(dry_run, state, args.swappiness)
        print()

    if dry_run:
        log("預覽結束，未做任何變更。如要實際執行，加上 --apply。")
        return 0

    all_ok = verify(size_bytes)
    print()

    if not all_ok:
        err("驗證失敗，請檢查上方錯誤訊息")
        return 1

    if needs_reboot or state.zswap_runtime_enabled is False:
        warn("需要重開機以啟用 zswap（磁碟 swapfile 已即時生效）")
        log("執行: sudo systemctl reboot")
    else:
        ok("遷移完成，所有參數就緒")
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except subprocess.CalledProcessError as e:
        err(f"命令執行失敗: {' '.join(e.cmd)}")
        if e.stderr:
            err(f"stderr: {e.stderr.strip()}")
        sys.exit(e.returncode)
    except KeyboardInterrupt:
        err("使用者中斷")
        sys.exit(130)
