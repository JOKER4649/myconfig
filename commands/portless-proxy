#!/usr/bin/env -S uv run --script
# /// script
# dependencies = ["typer"]
# ///
"""portless-proxy systemd service 管理工具"""

import subprocess
import sys
from typing import Annotated

import typer

SERVICE = "portless-proxy.service"
PROXY_URL = "https://localhost:1355"

app = typer.Typer(help="portless-proxy systemd service 管理工具")


def run(cmd: list[str], *, check: bool = True, capture: bool = False) -> subprocess.CompletedProcess:
    return subprocess.run(cmd, check=check, capture_output=capture, text=True)


@app.command()
def start():
    """啟動 service (含 daemon-reload)"""
    run(["systemctl", "--user", "daemon-reload"])
    run(["systemctl", "--user", "start", SERVICE])
    run(["systemctl", "--user", "--no-pager", "status", SERVICE])
    print(f"\n✓ portless proxy 已啟動 → {PROXY_URL}")


@app.command()
def stop():
    """停止 service"""
    run(["systemctl", "--user", "stop", SERVICE])
    print("✓ portless proxy 已停止")


@app.command()
def restart():
    """重新啟動 service (含 daemon-reload)"""
    run(["systemctl", "--user", "daemon-reload"])
    run(["systemctl", "--user", "restart", SERVICE])
    run(["systemctl", "--user", "--no-pager", "status", SERVICE])
    print(f"\n✓ portless proxy 已重新啟動 → {PROXY_URL}")


@app.command()
def logs(
    follow: Annotated[bool, typer.Option("-f", "--follow", help="持續追蹤新日誌 (tail -f 模式)")] = False,
    lines: Annotated[int, typer.Option("-n", "--lines", help="顯示最近 N 行")] = 50,
):
    """查看 service 日誌"""
    cmd = ["journalctl", "--user", "-u", SERVICE, "--no-pager", "-n", str(lines)]
    if follow:
        cmd.append("-f")
    run(cmd, check=False)


@app.command()
def status():
    """查看 service 狀態"""
    run(["systemctl", "--user", "--no-pager", "status", SERVICE], check=False)
    # 顯示 portless 路由
    print("\n--- 路由表 ---")
    run(["portless", "list"], check=False)


@app.command()
def trust():
    """安裝 CA 憑證到系統信任儲存區 (需要 sudo，僅需執行一次)"""
    print("安裝 portless CA 到系統信任儲存區...")
    # 不要用 sudo portless trust — sudo 會改變 HOME，導致讀到錯誤的 state dir
    # 讓 portless 自行處理升權，它會保留正確的 PORTLESS_STATE_DIR (PR #187)
    run(["portless", "trust"])
    print("✓ CA 已安裝，瀏覽器不再顯示憑證警告")


if __name__ == "__main__":
    try:
        app()
    except subprocess.CalledProcessError as e:
        sys.exit(e.returncode)
