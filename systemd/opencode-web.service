[Unit]
Description=OpenCode Web Interface
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=%h/.config/opencode-web/env
Environment=BROWSER=true
ExecStart=%h/.local/share/mise/shims/opencode web --hostname 0.0.0.0 --port 4096
WorkingDirectory=%h
Restart=on-failure
RestartSec=5

# Memory limit
MemoryMax=8G
MemoryHigh=7G

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/.local/share/opencode %h/.config/opencode %h/.cache
PrivateTmp=true

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=opencode-web

[Install]
WantedBy=default.target
