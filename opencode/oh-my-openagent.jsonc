{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max",
      "ultrawork": {
        "model": "anthropic/claude-opus-4-7",
        "variant": "max"
      }
    },
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "prompt_append": "Explore thoroughly, then implement. Prefer small, testable changes."
    },
    "prometheus": {
      "model": "openai/gpt-5.4",
      "prompt_append": "Always interview first. Validate scope before planning."
    },
    "oracle": {
      "model": "opencode/gemini-3.1-pro",
      "variant": "high"
    },
    "librarian": {
      "model": "opencode/gemini-3-flash"
    },
    "explore": {
      "model": "github-copilot/grok-code-fast-1"
    },
    "multimodal-looker": {
      "model": "opencode/gemini-3.1-pro"
    },
    "metis": {
      "model": "openai/gpt-5.4"
    },
    "momus": {
      "prompt_append": "Focus on code quality, edge cases, and test coverage."
    },
    "atlas": {
      "model": "anthropic/claude-sonnet-4-6",
      "variant": "high"
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.4-mini"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "opencode/gemini-3.1-pro",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "artistry": {
      "model": "opencode/gemini-3.1-pro",
      "variant": "high"
    },
    "quick": {
      "model": "minimax-coding-plan/MiniMax-M2.7"
    },
    "unspecified-high": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    },
    "unspecified-low": {
      "model": "anthropic/claude-sonnet-4-6",
      "variant": "max"
    },
    "writing": {
      "model": "opencode/gemini-3-flash"
    }
  },
  "auto_update": true,
  "runtime_fallback": false,
  "sisyphus_agent": {
    "default_builder_enabled": false,
    "tasks": {
      "enabled": true,
      "storage_path": ".sisyphus/tasks",
      "claude_code_compat": false
    }
  },
  "disabled_hooks": [
    "keyword-detector"
  ],
  "disabled_skills": [
    "playwright",
    "dev-browser"
  ],
  "background_task": {
    "defaultConcurrency": 8,
    "providerConcurrency": {
      "anthropic": 5,
      "openai": 5,
      "google": 10,
      "github-copilot": 10,
      "opencode": 15
    }
  },
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  "comment_checker": {
    "custom_prompt": "考慮這些註解欄位：`Intent`, `Reason`, `Constraints`, `Caveats`。皆為非必填，僅在程式行為、設計動機、使用限制或風險對理解有實質幫助時，才添加或修改。如要刪除註解，請謹慎考慮。"
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
  "git_master": {
    "include_co_authored_by": false
  },
  "hashline_edit": true,
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true
  }
}
