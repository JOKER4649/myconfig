{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-zellij@latest",
    "@slkiser/opencode-quota@latest"
  ],
  "autoupdate": true,
  "model": "minimax/MiniMax-M3",
  "small_model": "opencode-go/deepseek-v4-flash",
  "permission": {
    "bash": {
      "pkill -f *": "deny"
    },
    "task": {
      "*": "deny",
      "oracle": "allow",
      "explore": "allow"
    },
    "external_directory": {
      "~/**": "allow",
      "/tmp/**": "allow",
      "~/.ssh/id_*": "deny",
      "~/.ssh/*.pem": "deny",
      "~/.config/gh/hosts.yml": "ask",
      "~/.config/gcloud/credentials*": "ask",
      "~/.config/gcloud/legacy_credentials/**": "ask",
      "~/.docker/config.json": "ask"
    }
  },
  "lsp": false,
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "showSessionTokens": true,
      "enabledProviders": "auto",
      "formatStyle": "grouped",
      "percentDisplayMode": "used"
    }
  }
}