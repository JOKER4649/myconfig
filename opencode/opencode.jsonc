{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-zellij@latest", "@slkiser/opencode-quota@latest"],
  "autoupdate": true,
  "model": "minimax-coding-plan/MiniMax-M3",
  "small_model": "opencode-go/deepseek-v4-flash",
  "permission": {
    "bash": {
      "pkill -f *": "deny",
    },
    // 所有 agent 都可以委派 explore 來查詢資料, vision 來解釋圖片, 但其他 subagent 採用白名單
    "task": {
      "*": "deny",
      "explore": "allow",
      "vision": "allow",
    },
    "external_directory": {
      "/tmp/*": "allow"
    },
    // 僅主模型可使用記憶工具
    "memory_*": "deny",
    // 僅 @query agent 可使用網路搜尋工具
    "websearch_*": "deny",
    "websearch-fallback_*": "deny",
    "brave-search_*": "deny",
  },
  "agent": {
    "plan": { "disable": true },
    "build": { "disable": true },
    "general": { "disable": true },
    "compaction": {
      "model": "minimax-coding-plan/MiniMax-M3",
    },
    "explore": {
      "permission": {
        // 不允許遞迴委派 explore
        "task": "deny",
        // @explore 有完整網路搜尋能力
        "websearch_*": "allow",
        "websearch-fallback_*": "allow",
        "brave-search_*": "allow",
      },
    },
  },
  "lsp": true,
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
    },
    // Hindsight 是本地 long-term memory stack (services/hindsight/)。
    // opencode 端 key 叫 `memory`,tools 就會是 memory_retain / memory_recall /
    // memory_reflect 等,語意更貼模型使用情境(避免 hindsight_* 雙重 prefix)。
    //  - URL 綁 127.0.0.1:8888 而非 0.0.0.0:跟 docker-compose 的 port mapping 一致。
    //  - X-Bank-Id: joker 已綁預設 bank,retain/recall/reflect 不用帶 bank_id。
    //    之後要切別的 bank:把 headers 拿掉(讓模型 list_banks 選),或換成別的值。
    //  - reflect 會打 LLM,30s 預設 timeout 可能踩到,失敗再手動 retry。
    "memory": {
      "type": "remote",
      "url": "http://127.0.0.1:8888/mcp",
      "headers": {
        "X-Bank-Id": "joker",
      },
    },
  },
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "showSessionTokens": true,
      "enabledProviders": "auto",
      "formatStyle": "grouped",
      "percentDisplayMode": "used",
    },
  },
}
