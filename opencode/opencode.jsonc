{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    // "oh-my-openagent@latest",
    // "oh-my-opencode-slim",
    // "@ex-machina/opencode-anthropic-auth",
    "opencode-zellij@latest",
    "@slkiser/opencode-quota@latest",
    "@rama_nigg/open-cursor@latest",
  ],
  "autoupdate": true,
  "default_agent": "Hephaestus - Deep Agent",
  "model": "opencode-go/deepseek-v4-pro",
  "small_model": "opencode-go/deepseek-v4-flash",
  "permission": {
    "bash": {
      "pkill -f *": "deny",
    },
    // 工作目錄外的檔案存取：「家目錄全允許 + 敏感例外」策略
    // 順序敏感：opencode 採「最後 match 勝出」，deny/ask 例外必須放在 allow 之後
    "external_directory": {
      // 家目錄與系統 temp：myconfig 管理 dotfile 的主場
      "~/**": "allow",
      "/tmp/**": "allow",
      "/var/tmp/**": "allow",
      // 高敏感金鑰類 → deny（外洩無法 revoke 重發）
      "~/.ssh/id_*": "deny",
      "~/.ssh/*.pem": "deny",
      "~/.gnupg/**": "deny",
      "~/.password-store/**": "deny",
      "~/.config/sops/**": "deny",
      // Token / credential 類 → ask（除錯時可手動放行，外洩可 revoke）
      "~/.aws/credentials*": "ask",
      "~/.config/gh/hosts.yml": "ask",
      "~/.config/gcloud/credentials*": "ask",
      "~/.config/gcloud/legacy_credentials/**": "ask",
      "~/.netrc": "ask",
      "~/.pgpass": "ask",
      "~/.kube/config": "ask",
      "~/.docker/config.json": "ask",
      "~/.npmrc": "ask",
      "~/.pnpmrc": "ask",
      "~/.yarnrc": "ask",
    },
  },
  "agent": {
    "explore": {
      "disable": true,
    },
    "general": {
      "disable": true,
    },
    "plan": {
      "disable": true,
    },
    "build": {
      "disable": true,
    },
    "query-a": {
      "description": "",
      "prompt": "{file:./agents/query-a.md}",
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high",
    },
    "query-b": {
      "description": "",
      "prompt": "{file:./agents/query-a.md}",
      "model": "opencode-go/mimo-v2.5",
      "variant": "high",
    },
  },
  "lsp": true,
  "mcp": {},
  "provider": {
    "cursor-acp": {
      "name": "Cursor ACP",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:32124/v1",
      },
      "models": {
        "cursor-acp/auto": { "name": "Auto" },

        "cursor-acp/claude-opus-4-7": { "name": "Claude 4.7 Opus" },
        "cursor-acp/claude-4.6-sonnet": { "name": "Claude 4.6 Sonnet" },

        "cursor-acp/gpt-5.5": { "name": "GPT-5.5" },
        "cursor-acp/gpt-5.4": { "name": "GPT-5.4" },
        "cursor-acp/gpt-5.4-mini": { "name": "GPT-5.4 Mini" },
        "cursor-acp/gpt-5.4-nano": { "name": "GPT-5.4 Nano" },
        "cursor-acp/gpt-5.3-codex": { "name": "GPT-5.3 Codex" },

        "cursor-acp/gemini-3.1-pro": { "name": "Gemini 3.1 Pro" },
        "cursor-acp/gemini-3-flash": { "name": "Gemini 3 Flash" },

        "cursor-acp/composer-2.5": { "name": "Composer 2.5" },
        "cursor-acp/composer-2.5-fast": { "name": "Composer 2.5 Fast" },

        "cursor-acp/grok-4.3": { "name": "Grok 4.3" },
        "cursor-acp/kimi-k2.5": { "name": "Kimi K2.5" },
      },
    },
  },
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "showSessionTokens": true,
      "enabledProviders": "auto",
      "formatStyle": "grouped",
      "percentDisplayMode": "used",
    },
  },
}
