{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-zellij@latest", "@slkiser/opencode-quota@latest"],
  "autoupdate": true,
  "model": "minimax-coding-plan/MiniMax-M3",
  "small_model": "opencode-go/deepseek-v4-flash",
  "permission": {
    "bash": {
      "pkill -f *": "deny",
    },
    "task": {
      "*": "deny",
      "oracle": "allow",
      "explore": "allow",
    },
    "external_directory": {
      "~/**": "allow",
      "/tmp/**": "allow",
      "~/.ssh/id_*": "deny",
      "~/.ssh/*.pem": "deny",
      "~/.config/gh/hosts.yml": "ask",
      "~/.config/gcloud/credentials*": "ask",
      "~/.config/gcloud/legacy_credentials/**": "ask",
      "~/.docker/config.json": "ask",
    },
    // 全域禁掉所有 MCP tools:subagent 沒 override → 看不到,避免 explore/oracle
    // 帶 31 個 memory_retain/recall/reflect 等 tools 污染 context。
    // 只有 primary (build) 在下面 agent block 顯式 allow 拿回來。
    "memory_*": "deny",
    "context7_*": "deny",
    "grep_app_*": "deny",
  },
  "agent": {
    "plan": { "disable": true },
    "build": {
      "disable": false,
      // Primary agent override:MCP tools 拿回來。subagent 繼承上面的 deny。
      "permission": {
        "memory_*": "allow",
        "context7_*": "allow",
        "grep_app_*": "allow",
      },
    },
    "general": { "disable": true },
  },
  "lsp": false,
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
    },
    // Hindsight 是本地 long-term memory stack (services/hindsight/)。
    // opencode 端 key 叫 `memory`,tools 就會是 memory_retain / memory_recall /
    // memory_reflect 等,語意更貼模型使用情境(避免 hindsight_* 雙重 prefix)。
    //  - URL 綁 127.0.0.1:8888 而非 0.0.0.0:跟 docker-compose 的 port mapping 一致。
    //  - X-Bank-Id: joker 已綁預設 bank,retain/recall/reflect 不用帶 bank_id。
    //    之後要切別的 bank:把 headers 拿掉(讓模型 list_banks 選),或換成別的值。
    //  - reflect 會打 LLM,30s 預設 timeout 可能踩到,失敗再手動 retry。
    "memory": {
      "type": "remote",
      "url": "http://127.0.0.1:8888/mcp",
      "headers": {
        "X-Bank-Id": "joker",
      },
    },
  },
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "showSessionTokens": true,
      "enabledProviders": "auto",
      "formatStyle": "grouped",
      "percentDisplayMode": "used",
    },
  },
}
