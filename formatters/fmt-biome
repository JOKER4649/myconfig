#!/usr/bin/env bash
# Biome formatter wrapper：尊重專案層級配置，無則 fallback 全局 myconfig/biome/
#
# 用法：fmt-biome <file>
# 由 opencode formatter command 調用（opencode/opencode.jsonc 的 formatter.biome.command）
set -eu

FILE="${1:-}"
[ -n "$FILE" ] || {
  echo "usage: $(basename "$0") <file>" >&2
  exit 2
}

BIOME=/home/joker/.local/share/mise/shims/biome
GLOBAL_CONFIG=/home/joker/myconfig/biome

# 從 $FILE 所在目錄往上找 biome.json / biome.jsonc
dir=$(dirname "$(realpath "$FILE")")
while [ "$dir" != "/" ]; do
  if [ -f "$dir/biome.json" ] || [ -f "$dir/biome.jsonc" ]; then
    # 專案自己有 biome 配置 → 讓 biome 自動 find-up
    exec "$BIOME" check --write "$FILE"
  fi
  dir=$(dirname "$dir")
done

# Fallback 到全局配置
exec "$BIOME" check --write --config-path="$GLOBAL_CONFIG" "$FILE"
